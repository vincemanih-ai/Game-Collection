<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_blue_dark">

    <!-- Titre principal avec police Orbitron -->
    <TextView
        android:id="@+id/textCollectionTitle"
        style="@style/Text.Title.Main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ma Collection"
        android:textColor="@color/md_text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <!-- Carte Mes Jeux -->
    <LinearLayout
        android:id="@+id/cardMesJeux"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:orientation="vertical"
        android:background="@color/md_blue_light"
        android:padding="16dp"
        android:gravity="center"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/textCollectionTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/cardMesConsoles"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="24dp">

        <TextView
            style="@style/Text.Title.Section"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mes Jeux"
            android:textColor="@color/md_text_primary" />

        <TextView
            android:id="@+id/textNbJeux"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 jeux"
            android:textColor="@color/md_text_primary"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Carte Mes Consoles -->
    <LinearLayout
        android:id="@+id/cardMesConsoles"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:orientation="vertical"
        android:background="@color/md_orange"
        android:padding="16dp"
        android:gravity="center"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/textCollectionTitle"
        app:layout_constraintStart_toEndOf="@id/cardMesJeux"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="24dp">

        <TextView
            style="@style/Text.Title.Section"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mes Consoles"
            android:textColor="@color/md_text_primary" />

        <TextView
            android:id="@+id/textNbConsoles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 consoles"
            android:textColor="@color/md_text_primary"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Bloc Derniers ajouts -->
    <TextView
        android:id="@+id/textDerniersAjouts"
        style="@style/Text.Title.Section"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Derniers ajouts"
        android:textColor="@color/md_text_primary"
        app:layout_constraintTop_toBottomOf="@id/cardMesJeux"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/textDerniersAjoutsPlaceholder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="(bientôt les jaquettes de tes jeux)"
        android:textColor="@color/md_text_primary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/textDerniersAjouts"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp" />

    <!-- Barre de navigation du bas -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavCollection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/md_blue_dark"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@android:color/white"
        app:itemTextColor="@android:color/white"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>